name: phase2-kpi-guard

# PHASE2 KPI guard — Layer A/B/C 3계층 + meta 가드.
#
# 단일 출처:
#   - docs/PHASE2_GOVERNANCE_DESIGN.md (설계 문서)
#   - tests/phase2_rulebase/kpi_baseline.json (baseline)
#   - tests/phase2_rulebase/nightly_kpi_guard.py (가드 함수 — 후속 PR 에서 구현)
#
# 트리거:
#   - PR 대상 main / develop  (Layer A/B HARD FAIL = PR 차단, Layer C SOFT WARN = PR 코멘트)
#   - main 머지 시점 (post-merge 검증, 회귀 발생 시 issue 자동 생성)
#   - weekly cron (월요일 10:00 UTC, PHASE1 cron 09:00 보다 1시간 뒤로 runner 자원 충돌 회피)
#
# 원칙 (CLAUDE.md PHASE1 역할 원칙 계승, docs/PHASE2_GOVERNANCE_DESIGN.md §결정5):
#   PHASE2 향상은 도메인 정합성과 학습 무결성으로만 정당화한다.
#   truth recall 향상을 강제하는 가드 금지. Layer C 가드는 baseline 70% 비율 하한 SOFT WARN 만.
#   supervised 활성화 시 옵션 Q 전환 정책은 별도 design PR 의무.
#
# baseline 갱신 절차 (PHASE1 패턴 + D044 PR 템플릿 PHASE2 확장):
#   tests/phase2_rulebase/kpi_baseline.json 직접 편집 PR. description 에 변경 사유 +
#   도메인 정당성 + fitting-risk check + rollback 조건 명시 의무.
#
# Layer C SOFT WARN 누적 대응 (PHASE1 streak-reset 정책 그대로):
#   - PR: 코멘트만 남기고 차단하지 않음
#   - main/schedule/workflow_dispatch 3회 연속: kpi-guard issue 자동 생성 (label: phase2)
#   - 6회 연속: baseline 갱신 PR 또는 회귀 원인 분석 docs 의무
#   - 정상 run 1회 발생: streak reset (milestones lineage 초기화)

# DRAFT — 활성화 전 다음 의존 작업 필요:
#   1. tests/phase2_rulebase/nightly_kpi_guard.py 구현
#   2. tests/phase2_rulebase/kpi_baseline.json baseline 값 측정 PR
#   3. data/companies/_ci_baseline/engagements/2026/models/phase2_unsupervised/ CI baseline 모델 준비
#   4. 본 파일을 phase2-kpi-guard.yml 로 rename

on:
  pull_request:
    branches:
      - main
      - develop
    paths:
      - "src/preprocessing/**"
      - "src/detection/vae_detector.py"
      - "src/services/phase2_training_service.py"
      - "src/services/phase2_inference_service.py"
      - "src/services/phase2_evaluation.py"
      - "config/settings.py"
      - "tests/phase2_rulebase/**"
      - "artifacts/phase2_*"
  push:
    branches:
      - main
  schedule:
    - cron: "0 10 * * 1"
  workflow_dispatch: {}

permissions:
  contents: read
  pull-requests: write
  issues: write

jobs:
  kpi-guard:
    runs-on: ubuntu-latest
    timeout-minutes: 60
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 1

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install uv
        uses: astral-sh/setup-uv@v3
        with:
          version: "latest"

      - name: Sync dependencies
        run: uv sync --group core --group ml --group dev

      - name: Restore Layer C soft warn history
        id: softwarn-history-restore
        uses: actions/cache/restore@v4
        with:
          path: artifacts/_phase2_kpi_guard_softwarn_history.json
          key: phase2-kpi-guard-softwarn-${{ github.ref_name }}-${{ github.run_id }}
          restore-keys: |
            phase2-kpi-guard-softwarn-${{ github.ref_name }}-

      - name: Layer A + B + Meta (HARD FAIL)
        id: hard
        shell: bash
        run: |
          set -o pipefail
          uv run pytest tests/phase2_rulebase/nightly_kpi_guard.py \
            -v \
            -k "TestLayerADomainIntegrity or TestLayerBOperationalLoad or TestGuardMetaIntegrity" \
            --tb=short \
            2>&1 | tee artifacts/_phase2_kpi_guard_hard.log

      - name: Layer C (SOFT WARN, never fails)
        id: soft
        if: always()
        continue-on-error: true
        run: |
          uv run pytest tests/phase2_rulebase/nightly_kpi_guard.py \
            -v \
            -k "TestLayerCRankingRegressionSoftWarn" \
            -W "default::UserWarning" \
            --tb=no \
            2>&1 | tee artifacts/_phase2_kpi_guard_soft.log

      - name: Update Layer C soft warn history
        id: soft_history
        if: always()
        uses: actions/github-script@v7
        with:
          script: |
            const fs = require('fs');
            const path = 'artifacts/_phase2_kpi_guard_softwarn_history.json';
            let softLog = '';
            try { softLog = fs.readFileSync('artifacts/_phase2_kpi_guard_soft.log', 'utf8'); } catch (_) {}
            const softWarns = (softLog.match(/SOFT WARN/g) || []).length;
            let history = {
              consecutive_count: 0,
              last_soft_warn_count: 0,
              last_run_id: null,
              last_sha: null,
              milestones_opened: [],
              runs: [],
            };
            try {
              history = { ...history, ...JSON.parse(fs.readFileSync(path, 'utf8')) };
            } catch (_) {}

            const previousCount = Number(history.consecutive_count || 0);
            const consecutive = softWarns > 0 ? previousCount + 1 : 0;
            const milestone = consecutive >= 6 ? 6 : (consecutive >= 3 ? 3 : 0);
            // streak-reset 정책 (PHASE1 동일): 정상 run 1회로 milestones 초기화 → 재누적 시 issue 재발화.
            const milestonesOpened = softWarns === 0
              ? []
              : (Array.isArray(history.milestones_opened) ? history.milestones_opened : []);
            const shouldCreateIssue =
              context.eventName !== 'pull_request'
              && softWarns > 0
              && milestone > 0
              && !milestonesOpened.includes(milestone);

            const runRecord = {
              run_id: context.runId,
              event_name: context.eventName,
              sha: context.sha,
              ref: context.ref,
              soft_warn_count: softWarns,
              consecutive_count: consecutive,
              observed_at: new Date().toISOString(),
            };
            const runs = Array.isArray(history.runs) ? history.runs : [];
            runs.push(runRecord);
            const nextHistory = {
              ...history,
              consecutive_count: consecutive,
              last_soft_warn_count: softWarns,
              last_run_id: context.runId,
              last_sha: context.sha,
              last_ref: context.ref,
              updated_at: runRecord.observed_at,
              milestones_opened: shouldCreateIssue
                ? [...milestonesOpened, milestone]
                : milestonesOpened,
              runs: runs.slice(-12),
            };
            fs.mkdirSync('artifacts', { recursive: true });
            fs.writeFileSync(path, JSON.stringify(nextHistory, null, 2) + '\n');

            core.setOutput('soft_warns', String(softWarns));
            core.setOutput('consecutive_count', String(consecutive));
            core.setOutput('milestone', String(milestone));
            core.setOutput('should_create_issue', shouldCreateIssue ? 'true' : 'false');

      - name: Upload guard logs
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: phase2-kpi-guard-logs
          path: artifacts/_phase2_kpi_guard_*.log
          retention-days: 30

      - name: PR comment — Layer A/B/C summary
        if: github.event_name == 'pull_request' && always()
        uses: actions/github-script@v7
        with:
          script: |
            const fs = require('fs');
            let hardLog = '';
            let softLog = '';
            try { hardLog = fs.readFileSync('artifacts/_phase2_kpi_guard_hard.log', 'utf8'); } catch (_) {}
            try { softLog = fs.readFileSync('artifacts/_phase2_kpi_guard_soft.log', 'utf8'); } catch (_) {}
            const hardPass = !hardLog.includes('FAILED') && hardLog.includes('passed');
            const softWarns = (softLog.match(/SOFT WARN/g) || []).length;
            const verdict = hardPass
              ? '✅ Layer A/B HARD PASS'
              : '❌ Layer A/B HARD FAIL — PR 차단';
            const layerCMsg = softWarns > 0
              ? `⚠️ Layer C SOFT WARN ${softWarns}건 (검토 권장, 차단 아님)`
              : '✅ Layer C 회귀 없음';
            const body = [
              '## PHASE2 KPI Guard',
              '',
              `**Layer A/B (HARD)**: ${verdict}`,
              `**Layer C (SOFT WARN)**: ${layerCMsg}`,
              '',
              '<details><summary>Layer A/B 로그</summary>',
              '',
              '```',
              hardLog.split('\n').slice(-40).join('\n'),
              '```',
              '',
              '</details>',
              '',
              '<details><summary>Layer C 로그</summary>',
              '',
              '```',
              softLog.split('\n').slice(-40).join('\n'),
              '```',
              '',
              '</details>',
              '',
              '> **원칙**: PHASE2 향상은 도메인 정합성과 학습 무결성으로만 정당화. Layer C 는 회귀 방지선 (SOFT WARN), 향상 강제 금지.',
              '> baseline 갱신은 `tests/phase2_rulebase/kpi_baseline.json` 편집 PR + 도메인 사유 + fitting-risk check (D044 확장).',
              '> 설계: docs/PHASE2_GOVERNANCE_DESIGN.md',
            ].join('\n');
            github.rest.issues.createComment({
              owner: context.repo.owner,
              repo: context.repo.repo,
              issue_number: context.issue.number,
              body,
            });

      - name: Issue — Layer C consecutive SOFT WARN
        if: steps.soft_history.outputs.should_create_issue == 'true'
        uses: actions/github-script@v7
        with:
          script: |
            const fs = require('fs');
            const softWarns = Number('${{ steps.soft_history.outputs.soft_warns }}');
            const consecutive = Number('${{ steps.soft_history.outputs.consecutive_count }}');
            const milestone = Number('${{ steps.soft_history.outputs.milestone }}');
            let softLog = '';
            let history = '';
            try { softLog = fs.readFileSync('artifacts/_phase2_kpi_guard_soft.log', 'utf8'); } catch (_) {}
            try { history = fs.readFileSync('artifacts/_phase2_kpi_guard_softwarn_history.json', 'utf8'); } catch (_) {}
            const requiredAction = milestone >= 6
              ? 'baseline 갱신 PR 또는 회귀 원인 분석 docs 작성 의무. fitting 위험 확인 시 변경 롤백.'
              : 'Layer C SOFT WARN 3회 연속. 회귀 원인 확인 + kpi_baseline 갱신 필요성 검토.';
            await github.rest.issues.create({
              owner: context.repo.owner,
              repo: context.repo.repo,
              title: `[KPI Guard PHASE2] Layer C SOFT WARN ${consecutive} consecutive runs (${context.sha.substring(0,7)})`,
              labels: ['kpi-guard', 'phase2', 'soft-warn'],
              body: [
                '## Layer C SOFT WARN 누적 대응 (PHASE2)',
                '',
                `commit: \`${context.sha}\``,
                `workflow: ${context.serverUrl}/${context.repo.owner}/${context.repo.repo}/actions/runs/${context.runId}`,
                `soft warns in this run: ${softWarns}`,
                `consecutive count: ${consecutive}`,
                '',
                '### required action',
                requiredAction,
                '',
                '### 설계 참조',
                '- docs/PHASE2_GOVERNANCE_DESIGN.md §결정4 Layer C',
                '- docs/PHASE2_GOVERNANCE_DESIGN.md §6.4 승격 PR 템플릿 (fitting-risk check)',
                '',
                '### Layer C 로그',
                '```',
                softLog.split('\n').slice(-80).join('\n'),
                '```',
                '',
                '<details><summary>soft warn history</summary>',
                '',
                '```json',
                history,
                '```',
                '',
                '</details>',
              ].join('\n'),
            });

      - name: Save Layer C soft warn history
        if: always() && github.event_name != 'pull_request'
        uses: actions/cache/save@v4
        with:
          path: artifacts/_phase2_kpi_guard_softwarn_history.json
          key: phase2-kpi-guard-softwarn-${{ github.ref_name }}-${{ github.run_id }}

      - name: Post-merge issue — Layer A/B regression
        if: always() && github.event_name == 'push' && github.ref == 'refs/heads/main' && steps.hard.outcome == 'failure'
        uses: actions/github-script@v7
        with:
          script: |
            const fs = require('fs');
            let log = '';
            try { log = fs.readFileSync('artifacts/_phase2_kpi_guard_hard.log', 'utf8'); } catch (_) {}
            await github.rest.issues.create({
              owner: context.repo.owner,
              repo: context.repo.repo,
              title: `[KPI Guard PHASE2] Layer A/B regression on main (${context.sha.substring(0,7)})`,
              labels: ['kpi-guard', 'regression', 'phase2'],
              body: [
                '## post-merge KPI Guard 회귀 (PHASE2)',
                '',
                `commit: \`${context.sha}\``,
                `workflow: ${context.serverUrl}/${context.repo.owner}/${context.repo.repo}/actions/runs/${context.runId}`,
                '',
                '### 설계 참조',
                '- docs/PHASE2_GOVERNANCE_DESIGN.md',
                '',
                '### 로그',
                '```',
                log.split('\n').slice(-60).join('\n'),
                '```',
              ].join('\n'),
            });
